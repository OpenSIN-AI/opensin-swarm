{
  "description": "Realistic routing and selector benchmark corpus for OMOC Swarm",
  "version": "1.0.0",
  "routing": {
    "description": "Agent routing test cases covering legacy aliases, canonical IDs, and edge cases",
    "testCases": [
      {
        "category": "legacy-aliases",
        "description": "Legacy role names that should resolve to canonical agent IDs",
        "cases": [
          { "input": "planner", "expected": "plan", "rationale": "Legacy planner role" },
          { "input": "researcher", "expected": "explore", "rationale": "Legacy researcher role" },
          { "input": "coder", "expected": "build", "rationale": "Legacy coder role" },
          { "input": "reviewer", "expected": "general", "rationale": "Legacy reviewer role" },
          { "input": "PLANNER", "expected": "plan", "rationale": "Case insensitive legacy" },
          { "input": "Planner", "expected": "plan", "rationale": "Mixed case legacy" }
        ]
      },
      {
        "category": "canonical-ids",
        "description": "Canonical agent IDs that should resolve to themselves",
        "cases": [
          { "input": "plan", "expected": "plan", "rationale": "Canonical planning agent" },
          { "input": "build", "expected": "build", "rationale": "Canonical build agent" },
          { "input": "explore", "expected": "explore", "rationale": "Canonical exploration agent" },
          { "input": "general", "expected": "general", "rationale": "Canonical general agent" },
          { "input": "metis", "expected": "metis", "rationale": "Metis strategic agent" },
          { "input": "momus", "expected": "momus", "rationale": "Momus critic agent" },
          { "input": "oracle", "expected": "oracle", "rationale": "Oracle knowledge agent" },
          { "input": "librarian", "expected": "librarian", "rationale": "Librarian documentation agent" }
        ]
      },
      {
        "category": "unknown-agents",
        "description": "Unknown or invalid agent IDs that should return null",
        "cases": [
          { "input": "unknown-agent", "expected": null, "rationale": "Completely unknown agent" },
          { "input": "", "expected": null, "rationale": "Empty string" },
          { "input": "invalid_agent", "expected": null, "rationale": "Invalid format" },
          { "input": "nonexistent", "expected": null, "rationale": "Non-existent agent" },
          { "input": "build2", "expected": null, "rationale": "Similar but wrong name" },
          { "input": "builder", "expected": null, "rationale": "Common typo for build" },
          { "input": "planning", "expected": null, "rationale": "Verb form instead of noun" },
          { "input": "explorer", "expected": null, "rationale": "Common confusion with explore" },
          { "input": "generality", "expected": null, "rationale": "Wrong word form" },
          { "input": "cooder", "expected": null, "rationale": "Misspelling of coder" },
          { "input": "anlyzer", "expected": null, "rationale": "Misspelling of analyzer" }
        ]
      },
      {
        "category": "operator-mistakes",
        "description": "Real-world operator input mistakes and typos",
        "cases": [
          { "input": "  planner  ", "expected": "plan", "rationale": "Extra whitespace" },
          { "input": "planner\t", "expected": "plan", "rationale": "Trailing tab" },
          { "input": "\nresearcher", "expected": "explore", "rationale": "Leading newline" },
          { "input": "BuiLd", "expected": "build", "rationale": "Random casing" },
          { "input": "EXPLORE", "expected": "explore", "rationale": "All uppercase canonical" },
          { "input": "ExPlOrE", "expected": "explore", "rationale": "Alternating case" },
          { "input": "m  e  t  i  s", "expected": null, "rationale": "Spaces in middle should fail" },
          { "input": "metis ", "expected": "metis", "rationale": "Trailing space on valid agent" }
        ]
      },
      {
        "category": "near-miss-ids",
        "description": "Agent IDs that are close to valid but should still fail",
        "cases": [
          { "input": "planer", "expected": null, "rationale": "Missing 'n' from planner" },
          { "input": "planing", "expected": null, "rationale": "Missing 'n' in planning" },
          { "input": "bild", "expected": null, "rationale": "German spelling of build" },
          { "input": "bilds", "expected": null, "rationale": "Pluralized build typo" },
          { "input": "buildd", "expected": null, "rationale": "Double letter typo" },
          { "input": "explorr", "expected": null, "rationale": "Double letter explore" },
          { "input": "explor", "expected": null, "rationale": "Missing 'e' from explore" },
          { "input": "genera", "expected": null, "rationale": "Substring of general" },
          { "input": "generals", "expected": null, "rationale": "Pluralized general" },
          { "input": "metiss", "expected": null, "rationale": "Double 's' on metis" },
          { "input": "momous", "expected": null, "rationale": "Vowel swap in momus" },
          { "input": "libary", "expected": null, "rationale": "Common misspelling of library" },
          { "input": "libratrian", "expected": null, "rationale": "Extra syllable in librarian" }
        ]
      }
    ]
  },
  "selector": {
    "description": "Selector benchmark cases for MAX mode winner selection",
    "testCases": [
      {
        "scenario": "minimal-safe-patch",
        "description": "Prefer smallest correct solution when tests pass",
        "prompt": "Prefer the smallest safe patch with passing tests.",
        "selectionCriteria": {
          "priority": "test-status",
          "secondary": "diff-size",
          "tertiary": "file-count"
        },
        "cases": [
          {
            "name": "a",
            "changedFiles": 4,
            "testExitCode": 0,
            "diffSize": 3200,
            "description": "Large change, tests pass"
          },
          {
            "name": "b",
            "changedFiles": 1,
            "testExitCode": 0,
            "diffSize": 900,
            "description": "Small change, tests pass - WINNER"
          },
          {
            "name": "c",
            "changedFiles": 2,
            "testExitCode": 1,
            "diffSize": 700,
            "description": "Small change, tests fail"
          }
        ],
        "expected": "b"
      },
      {
        "scenario": "correctness-over-size",
        "description": "Prefer correctness even if solution is larger",
        "prompt": "Prefer correctness over size when tests fail.",
        "selectionCriteria": {
          "priority": "test-status",
          "secondary": "correctness",
          "tertiary": "maintainability"
        },
        "cases": [
          {
            "name": "a",
            "changedFiles": 1,
            "testExitCode": 1,
            "diffSize": 300,
            "description": "Small but failing"
          },
          {
            "name": "b",
            "changedFiles": 2,
            "testExitCode": 1,
            "diffSize": 200,
            "description": "Smallest but failing"
          },
          {
            "name": "c",
            "changedFiles": 3,
            "testExitCode": 0,
            "diffSize": 1400,
            "description": "Larger but correct - WINNER"
          }
        ],
        "expected": "c"
      },
      {
        "scenario": "test-failure-penalty",
        "description": "Heavy penalty for test failures regardless of size",
        "prompt": "Tests must pass; prefer minimal changes otherwise.",
        "selectionCriteria": {
          "priority": "test-status",
          "secondary": "diff-size"
        },
        "cases": [
          {
            "name": "x",
            "changedFiles": 10,
            "testExitCode": 0,
            "diffSize": 5000,
            "description": "Large but passing - WINNER"
          },
          {
            "name": "y",
            "changedFiles": 1,
            "testExitCode": 1,
            "diffSize": 100,
            "description": "Tiny but failing"
          },
          {
            "name": "z",
            "changedFiles": 2,
            "testExitCode": 1,
            "diffSize": 200,
            "description": "Small but failing"
          }
        ],
        "expected": "x"
      },
      {
        "scenario": "file-count-matters",
        "description": "When tests equal, prefer fewer file changes",
        "prompt": "Make surgical changes; touch as few files as possible.",
        "selectionCriteria": {
          "priority": "test-status",
          "secondary": "file-count",
          "tertiary": "diff-size"
        },
        "cases": [
          {
            "name": "surgical",
            "changedFiles": 1,
            "testExitCode": 0,
            "diffSize": 1500,
            "description": "Single file, moderate size - WINNER"
          },
          {
            "name": "scattered",
            "changedFiles": 8,
            "testExitCode": 0,
            "diffSize": 1200,
            "description": "Many files, smaller total"
          }
        ],
        "expected": "surgical"
      },
      {
        "scenario": "refactor-preference",
        "description": "When both pass tests, smaller size wins (current scoring)",
        "prompt": "Make minimal changes; prefer smaller diffs.",
        "selectionCriteria": {
          "priority": "test-status",
          "secondary": "diff-size"
        },
        "cases": [
          {
            "name": "hacky",
            "changedFiles": 2,
            "testExitCode": 0,
            "diffSize": 400,
            "description": "Small change, tests pass - WINNER"
          },
          {
            "name": "clean",
            "changedFiles": 5,
            "testExitCode": 0,
            "diffSize": 2200,
            "description": "Larger change, tests pass"
          }
        ],
        "expected": "hacky"
      },
      {
        "scenario": "real-swarm-fix",
        "description": "Real swarm scenario: bug fix with minimal changes",
        "prompt": "Fix the authentication bug; minimize side effects.",
        "selectionCriteria": {
          "priority": "test-status",
          "secondary": "file-count",
          "tertiary": "diff-size"
        },
        "cases": [
          {
            "name": "comprehensive",
            "changedFiles": 12,
            "testExitCode": 0,
            "diffSize": 4500,
            "description": "Fixes bug but touches many files"
          },
          {
            "name": "targeted",
            "changedFiles": 2,
            "testExitCode": 0,
            "diffSize": 800,
            "description": "Targeted fix, minimal files - WINNER"
          },
          {
            "name": "incomplete",
            "changedFiles": 1,
            "testExitCode": 1,
            "diffSize": 200,
            "description": "Smallest but tests fail"
          }
        ],
        "expected": "targeted"
      },
      {
        "scenario": "feature-implementation",
        "description": "Real swarm scenario: new feature implementation",
        "prompt": "Implement the feature; prefer minimal correct solution.",
        "selectionCriteria": {
          "priority": "test-status",
          "secondary": "diff-size",
          "tertiary": "file-count"
        },
        "cases": [
          {
            "name": "minimal",
            "changedFiles": 3,
            "testExitCode": 0,
            "diffSize": 600,
            "description": "Minimal correct implementation - WINNER"
          },
          {
            "name": "complete",
            "changedFiles": 5,
            "testExitCode": 0,
            "diffSize": 1800,
            "description": "More complete but larger"
          },
          {
            "name": "overengineered",
            "changedFiles": 10,
            "testExitCode": 0,
            "diffSize": 5000,
            "description": "Overengineered solution"
          }
        ],
        "expected": "minimal"
      },
      {
        "scenario": "performance-fix",
        "description": "Real swarm scenario: performance optimization",
        "prompt": "Improve performance; maintain correctness.",
        "selectionCriteria": {
          "priority": "test-status",
          "secondary": "diff-size",
          "tertiary": "file-count"
        },
        "cases": [
          {
            "name": "risky",
            "changedFiles": 8,
            "testExitCode": 0,
            "diffSize": 3000,
            "description": "Large refactor, tests pass"
          },
          {
            "name": "conservative",
            "changedFiles": 3,
            "testExitCode": 0,
            "diffSize": 1200,
            "description": "Targeted optimization - WINNER"
          },
          {
            "name": "broken",
            "changedFiles": 2,
            "testExitCode": 1,
            "diffSize": 500,
            "description": "Broken optimization"
          }
        ],
        "expected": "conservative"
      },
      {
        "scenario": "test-only-change",
        "description": "Real swarm scenario: test improvement without logic changes",
        "prompt": "Add test coverage for edge cases.",
        "selectionCriteria": {
          "priority": "test-status",
          "secondary": "file-count",
          "tertiary": "diff-size"
        },
        "cases": [
          {
            "name": "focused",
            "changedFiles": 1,
            "testExitCode": 0,
            "diffSize": 400,
            "description": "Single test file - WINNER"
          },
          {
            "name": "scattered",
            "changedFiles": 5,
            "testExitCode": 0,
            "diffSize": 350,
            "description": "Multiple test files"
          }
        ],
        "expected": "focused"
      }
    ]
  },
  "edgeCases": {
    "description": "Edge cases for robustness testing",
    "routing": [
      { "input": "  plan  ", "expected": "plan", "rationale": "Whitespace trimming" },
      { "input": "PLAN", "expected": "plan", "rationale": "Uppercase canonical" },
      { "input": "PlAn", "expected": "plan", "rationale": "Mixed case canonical" }
    ],
    "selector": {
      "testCases": [
        {
          "scenario": "tie-breaker",
          "description": "When all metrics equal, use deterministic tie-breaker",
          "prompt": "All candidates are equal; pick first.",
          "cases": [
            { "name": "a", "changedFiles": 2, "testExitCode": 0, "diffSize": 1000 },
            { "name": "b", "changedFiles": 2, "testExitCode": 0, "diffSize": 1000 }
          ],
          "expected": "a",
          "rationale": "First in list wins ties"
        }
      ]
    }
  }
}
